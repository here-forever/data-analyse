# Application
APP_NAME="Data Analysis System"
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=replace-with-a-random-local-secret
# Stable key used to encrypt external database credentials. Changing it makes existing credentials unreadable.
EXTERNAL_CONNECTION_ENCRYPTION_KEY=replace-with-a-separate-random-encryption-key

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000/api
# Development-only token. Never reuse it for a public deployment.
VITE_DEV_ACCESS_TOKEN=local-dev-token-usr_admin

# PostgreSQL - local or future Docker Compose
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=data_analysis_system
POSTGRES_USER=data_analysis_user
POSTGRES_PASSWORD=replace-with-a-local-database-password
DATABASE_URL=postgresql+psycopg://data_analysis_user:replace-with-a-local-database-password@127.0.0.1:5432/data_analysis_system

# Redis - reserved for task center/cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# Local file storage
LOCAL_STORAGE_ROOT=./storage
UPLOAD_STORAGE_ROOT=./storage/uploads

# Security defaults
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_HASH_SCHEME=bcrypt
